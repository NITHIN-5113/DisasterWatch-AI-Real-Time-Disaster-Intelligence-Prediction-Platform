# ─────────────────────────────────────────────────────────
# DisasterWatch Full-Stack Application
# Environment Configuration
# ─────────────────────────────────────────────────────────

# ── Frontend Configuration ────────────────────────────────
# API endpoint for frontend communication
API_BASE_URL=http://localhost:4000/api/v1

# ── Backend Configuration ─────────────────────────────────
# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database (SQLite for development)
DATABASE_URL="file:./dev.db"

# JWT Secrets (Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=your_access_secret_minimum_32_chars_change_this
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_chars_change_this
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000
