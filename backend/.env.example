# ─────────────────────────────────────────────────────────
# DisasterWatch Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=4000
LOG_LEVEL=info                # error | warn | info | debug

# ── Database ──────────────────────────────────
# SQLite connection string for local development
# Format: file:./dev.db
DATABASE_URL="file:./dev.db"

# PostgreSQL connection string for production
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/disasterwatch?schema=public"

# ── JWT ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_minimum_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_minimum_32_chars
JWT_ACCESS_TTL=15m            # Access token lifetime  (e.g. 15m, 1h)
JWT_REFRESH_TTL=7d            # Refresh token lifetime (e.g. 7d, 30d)

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://disasterwatch.app,https://staging.disasterwatch.app
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
